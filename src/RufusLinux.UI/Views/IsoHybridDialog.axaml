<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RufusLinux.UI.ViewModels"
        xmlns:loc="using:RufusLinux.UI.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="180"
        x:Class="RufusLinux.UI.Views.IsoHybridDialog"
        x:DataType="vm:IsoHybridDialogViewModel"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="{x:Static loc:Strings.IsoHybridTitle}">

    <Design.DataContext>
        <vm:IsoHybridDialogViewModel/>
    </Design.DataContext>

    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
            <Button Content="{x:Static loc:Strings.UseNtfsButton}" Command="{Binding UseNtfsCommand}"/>
            <Button Content="{x:Static loc:Strings.KeepFat32Button}" Command="{Binding KeepFat32Command}"/>
            <Button Content="{x:Static loc:Strings.CancelButton}" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
